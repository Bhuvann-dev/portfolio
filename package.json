{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\"",
    "build": "cd apps/web && npm install && npx vite build",
    "start": "cd apps/web && npm start",
    "lint": "cd apps/web && npm run lint",
    "predeploy": "cd apps/web && npm run build",
    "deploy": "gh-pages -d dist/apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "gh-pages": "^6.3.0"
  },
  "workspaces": [
    "apps/*"
  ]
}
